@model IEnumerable<EProject.Web.Entities.Project>

@{
    ViewData["Title"] = "Search Projects";
    int? currentUserId = ViewBag.CurrentUserId as int?;
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-10">

        <div class="mb-3">
            <a class="btn btn-outline-secondary btn-sm"
                   asp-controller="Home"
                   asp-action="Index">
                ← Back
            </a>
        </div>

        <div class="mb-4">
            <h1 class="h2 fw-bold mb-1">Search Projects</h1>
            <p class="text-muted mb-0">
                Search all projects by title, description, author, or programming language.
            </p>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">
                <form asp-controller="Search" asp-action="Index" method="get" class="d-flex flex-column flex-md-row gap-3">
                    <input type="text"
                           name="searchString"
                           class="form-control form-control-lg"
                           placeholder="Enter a search string..."
                           value="@ViewBag.SearchTerm" />

                    <button type="submit" class="btn btn-primary px-4">
                        Search
                    </button>
                </form>
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="card shadow-sm border-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="px-4 py-3">Title</th>
                                <th class="py-3">Description</th>
                                <th class="py-3">Author</th>
                                <th class="py-3">Language</th>
                                <th class="py-3">Status</th>
                                <th class="px-4 py-3 text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var project in Model)
                            {
                                var statusClass = project.Status?.Trim().ToLower() switch
                                {
                                    "complete" => "bg-success text-white",
                                    "in-progress" => "bg-warning text-dark",
                                    "pending" => "bg-secondary text-white",
                                    _ => "bg-dark text-white"
                                };

                                var shortDescription = !string.IsNullOrWhiteSpace(project.Description) && project.Description.Length > 100
                                    ? project.Description.Substring(0, 100) + "..."
                                    : project.Description;

                                bool isOwner = currentUserId.HasValue && project.UserAccountId == currentUserId.Value;
                                bool canDelete = isOwner && project.Status?.Trim().ToLower() != "in-progress";

                                <tr>
                                    <td class="px-4 py-3 fw-bold">@project.Title</td>
                                    <td class="py-3 text-muted">@shortDescription</td>
                                    <td class="py-3">@project.Author</td>
                                    <td class="py-3">@project.ProgrammingLanguage</td>
                                    <td class="py-3">
                                        <span class="badge rounded-pill @statusClass">
                                            @project.Status
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 text-end">
                                        @if (isOwner)
                                        {
                                            <a asp-controller="Projects"
                                                   asp-action="Edit"
                                                   asp-route-id="@project.Id"
                                                   class="btn btn-warning btn-sm text-dark">
                                                Edit
                                            </a>

                                            @if (canDelete)
                                            {
                                                <form asp-controller="Projects"
                                                      asp-action="Delete"
                                                      asp-route-id="@project.Id"
                                                      method="post"
                                                      class="d-inline"
                                                      onsubmit="return confirm('Are you sure you want to delete project @project.Title?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-danger btn-sm ms-1">
                                                        Delete
                                                    </button>
                                                </form>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(ViewBag.SearchTerm))
        {
            <div class="card shadow-sm border-0">
                <div class="card-body p-5 text-center">
                    <p class="text-muted mb-0 fs-5">
                        No projects found containing "<strong>@ViewBag.SearchTerm</strong>".
                    </p>
                </div>
            </div>
        }
    </div>
</div>