@model IEnumerable<EProject.Web.Entities.Project>

@{
    ViewData["Title"] = "My Projects";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-10">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-2">
            <div>
                <h1 class="h2 fw-bold mb-1">My Projects</h1>
                <p class="text-muted mb-0">Here you can view and edit your projects.</p>
            </div>

            <a asp-controller="Projects"
               asp-action="Create"
               asp-route-returnUrl="@Context.Request.Path"
               class="btn btn-primary">
                Add Project
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 text-center">
                    <p class="text-muted mb-3">You do not have any projects yet.</p>
                    <a asp-controller="Projects"
                       asp-action="Create"
                       class="btn btn-outline-primary">
                        Create Project
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var project in Model)
                {
                    <div class="col-12 col-md-6 col-xl-4">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-body p-4 d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-3 gap-2">
                                    <h2 class="h5 fw-bold mb-0">@project.Title</h2>

                                    <span class="badge text-bg-secondary">
                                        @project.Status
                                    </span>
                                </div>

                                <p class="text-muted mb-3 flex-grow-1">@project.Description</p>

                                <div class="small mb-3">
                                    <p class="mb-2">
                                        <span class="fw-semibold">Author:</span> @project.Author
                                    </p>
                                    <p class="mb-0">
                                        <span class="fw-semibold">Programming Language:</span> @project.ProgrammingLanguage
                                    </p>
                                </div>

                                <div class="mt-auto">
                                    <a asp-controller="Projects"
                                       asp-action="Edit"
                                       asp-route-id="@project.Id"
                                       class="btn btn-outline-primary btn-sm">
                                        Edit
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>