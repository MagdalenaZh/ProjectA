@model IEnumerable<EProject.Web.Entities.Project>

@{
    ViewData["Title"] = "My Projects";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-10">
        <div class="mb-3">
            <a class="btn btn-outline-secondary btn-sm"
                   asp-controller="Home"
                   asp-action="Index">
                ← Back
            </a>
        </div>

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-2">
            <div>
                <h1 class="h2 fw-bold mb-1">My Projects</h1>
                <p class="text-muted mb-0">Here you can view, edit, and delete your projects.</p>
            </div>

            <a asp-controller="Projects"
                   asp-action="Create"
                   asp-route-returnUrl="@Context.Request.Path"
                   class="btn btn-primary">
                Add Project
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 text-center">
                    <p class="text-muted mb-3">You do not have any projects yet.</p>
                    <a asp-controller="Projects"
                           asp-action="Create"
                           class="btn btn-outline-primary">
                        Create Project
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var project in Model)
                {
                    var statusClass = project.Status?.Trim().ToLower() switch
                    {
                        "complete" => "bg-success text-white",
                        "in-progress" => "bg-warning text-dark",
                        "pending" => "bg-secondary text-white",
                        _ => "bg-dark text-white"
                    };

                    var shortDescription = !string.IsNullOrWhiteSpace(project.Description) && project.Description.Length > 120
                        ? project.Description.Substring(0, 120) + "..."
                        : project.Description;

                    <div class="col-12 col-md-6 col-xl-4">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-body p-4 d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-3 gap-2">
                                    <h2 class="h5 fw-bold mb-0">@project.Title</h2>

                                    <span class="badge rounded-pill @statusClass">
                                        @project.Status
                                    </span>
                                </div>

                                <p class="text-muted mb-3 flex-grow-1">@shortDescription</p>

                                <div class="small mb-3">
                                    <p class="mb-2">
                                        <span class="fw-semibold">Author:</span> @project.Author
                                    </p>
                                    <p class="mb-0">
                                        <span class="fw-semibold">Programming Language:</span> @project.ProgrammingLanguage
                                    </p>
                                </div>

                                <div class="mt-auto d-flex justify-content-end gap-2 flex-wrap">
                                    <a asp-controller="Projects"
                                           asp-action="Details"
                                           asp-route-id="@project.Id"
                                           class="btn btn-outline-primary btn-sm">
                                        View
                                    </a>

                                    <a asp-controller="Projects"
                                           asp-action="Edit"
                                           asp-route-id="@project.Id"
                                           class="btn btn-warning btn-sm text-dark">
                                        Edit
                                    </a>

                                    @if (User.Identity != null && User.Identity.IsAuthenticated && project.Status?.Trim().ToLower() != "in-progress")
                                    {
                                        <form asp-controller="Projects"
                                              asp-action="Delete"
                                              asp-route-id="@project.Id"
                                              method="post"
                                              class="d-inline"
                                              onsubmit="return confirm('Are you sure you want to delete project @(project.Title)?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="btn btn-danger btn-sm">
                                                Delete
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>