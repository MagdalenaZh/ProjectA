@model EProject.Web.Entities.Project

@{
    ViewData["Title"] = "Project Details";

    var statusClass = Model.Status?.Trim().ToLower() switch
    {
        "complete" => "bg-success text-white",
        "in-progress" => "bg-warning text-dark",
        "pending" => "bg-secondary text-white",
        _ => "bg-dark text-white"
    };
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8 col-xl-7">
        <div class="mb-3">
            <a asp-controller="Projects"
                   asp-action="Index"
                   class="btn btn-outline-secondary btn-sm">
                ← Back to My Projects
            </a>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex justify-content-between align-items-start mb-4 gap-2">
                    <div>
                        <h1 class="h2 fw-bold mb-2">@Model.Title</h1>
                        <p class="text-muted mb-0">View the full information for this project.</p>
                    </div>

                    <span class="badge rounded-pill @statusClass">
                        @Model.Status
                    </span>
                </div>

                <div class="mb-4">
                    <h2 class="h6 fw-semibold">Description</h2>
                    <p class="mb-0">@Model.Description</p>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="border rounded p-3 h-100">
                            <p class="mb-1 fw-semibold">Author</p>
                            <p class="mb-0 text-muted">@Model.Author</p>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="border rounded p-3 h-100">
                            <p class="mb-1 fw-semibold">Programming Language</p>
                            <p class="mb-0 text-muted">@Model.ProgrammingLanguage</p>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="border rounded p-3 h-100">
                            <p class="mb-1 fw-semibold">Created At</p>
                            <p class="mb-0 text-muted">@Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</p>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="border rounded p-3 h-100">
                            <p class="mb-1 fw-semibold">Completed At</p>
                            <p class="mb-0 text-muted">
                                @(Model.CompletedAt.HasValue
                                    ? Model.CompletedAt.Value.ToLocalTime().ToString("dd MMM yyyy, HH:mm")
                                    : "Not completed yet")
                            </p>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <a asp-controller="Projects"
                           asp-action="Edit"
                           asp-route-id="@Model.Id"
                           class="btn btn-warning text-dark">
                        Edit
                    </a>

                    <a asp-controller="Projects"
                           asp-action="Index"
                           class="btn btn-outline-secondary">
                        Back
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>