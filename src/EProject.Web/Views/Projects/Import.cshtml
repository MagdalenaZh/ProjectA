@{
    ViewData["Title"] = "Import Projects";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="mb-4">
            <h1 class="h2 fw-bold mb-2">Import Projects</h1>
            <p class="text-muted">Upload a JSON file to import projects into your account.</p>
        </div>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-danger shadow-sm border-0 mb-4">
                <h5 class="alert-heading fw-bold">Import Failed</h5>
                <p class="mb-0">@ViewBag.ErrorMessage</p>
                
                @if (ViewBag.ValidationErrors != null)
                {
                    <hr />
                    <ul class="mb-0 small">
                        @foreach (var error in ViewBag.ValidationErrors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                }
            </div>
        }

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">Upload JSON File</h2>
                
                <form asp-controller="Import" asp-action="Upload" method="post" enctype="multipart/form-data">
                    <div class="mb-4">
                        <input type="file" name="importFile" class="form-control form-control-lg" accept=".json" required />
                    </div>
                    <button type="submit" class="btn btn-primary px-4">Upload and Import</button>
                </form>
            </div>
        </div>

        <div class="card shadow-sm border-0 bg-light">
            <div class="card-body p-4">
                <h2 class="h5 fw-bold mb-3">Required JSON Format</h2>
                <p class="small text-muted mb-3">Your file must contain an array of project objects because of the JSON schema.</p>
                <pre class="bg-dark text-white p-3 rounded small mb-0"><code>[
  {
    "Title": "Project Alpha",
    "Description": "A comprehensive description over 10 characters long.",
    "Author": "Jane Doe",
    "ProgrammingLanguage": "C#",
    "Status": "in-progress" // Must be: pending, in-progress, or complete
  }
]</code></pre>
            </div>
        </div>
    </div>
</div>