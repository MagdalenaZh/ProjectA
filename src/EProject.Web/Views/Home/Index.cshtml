@model IEnumerable<EProject.Web.Entities.Project>

@{
    ViewData["Title"] = "Home";
}

<div class="container-fluid px-0">
    <div class="row justify-content-center mb-4">
        <div class="col-12 col-lg-10">
            <div class="card border-0 shadow-sm rounded-4 bg-light">
                <div class="card-body p-4 p-md-5 text-center">
                    <h1 class="display-5 fw-bold mb-3">Welcome to e-Project</h1>
                    <p class="lead text-muted mb-0">
                        Manage and explore projects through a simple web interface.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-12 col-lg-10">
            <h2 class="h3 mb-4 fw-bold text-center text-md-start">Recently Completed Projects</h2>

            @if (Model != null && Model.Any(p => p.Status == "complete"))
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    @foreach (var project in Model.Where(p => p.Status == "complete").Take(5))
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0 border-top border-success border-4">
                                <div class="card-body p-4">
                                    <h3 class="h5 fw-bold mb-2">@project.Title</h3>
                                    <p class="text-muted small mb-3">@project.Description</p>
                                    <div class="mt-auto pt-2 border-top">
                                        <div class="d-flex justify-content-between">
                                            <span class="small"><strong>By:</strong> @project.Author</span>
                                            <span class="badge bg-success-subtle text-success border border-success-subtle">@project.Status</span>
                                        </div>
                                        <p class="mb-0 mt-1 small"><strong>Language:</strong> @project.ProgrammingLanguage</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-light border shadow-sm text-center">
                    No completed projects have been posted yet.
                </div>
            }
        </div>
    </div>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="row justify-content-center">
            <div class="col-12 col-lg-10">
                <div class="d-flex flex-row flex-md-row justify-content-between align-items-md-center mb-3 gap-2">
                    <div>
                        <h2 class="h3 mb-1">Your Projects</h2>
                    </div>

                    <div>
                        <a asp-controller="Projects"
                           asp-action="Create"
                           asp-route-returnUrl="@Context.Request.Path"
                           class="btn btn-primary">
                            Add Project
                        </a>
                    </div>
                </div>

               </div>
        </div>
    }
</div>