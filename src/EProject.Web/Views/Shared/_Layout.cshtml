<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EProject.Web</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EProject.Web.styles.css" asp-append-version="true" />
</head>

<body class="d-flex flex-column min-vh-100 bg-body-tertiary">
    <header>
        <nav class="navbar navbar-expand-lg bg-white border-bottom shadow-sm mb-4">
            <div class="container-fluid px-3 px-md-4 px-lg-5">
                <a class="navbar-brand fw-bold fs-4"
                       asp-controller="Home"
                       asp-action="Index">
                    e-Project
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div class="ms-auto d-flex flex-column flex-lg-row align-items-lg-center gap-2 gap-lg-3 mt-3 mt-lg-0">
                            <span class="text-dark fw-semibold">
                                Hello, @User.Identity.Name
                            </span>

                            <a asp-controller="Projects"
                                   asp-action="Create"
                                   asp-route-returnUrl="@Context.Request.Path"
                                   class="btn btn-primary btn-sm">
                                Add Project
                            </a>

                            <a asp-controller="Projects"
                                   asp-action="Index"
                                   class="nav-link text-dark p-0">
                                My Projects
                            </a>

                            <a asp-controller="Search"
                                   asp-action="Index"
                                   class="nav-link text-dark p-0">
                                Search
                            </a>

                            <a asp-controller="Import"
                                   asp-action="Index"
                                   class="nav-link text-dark p-0">
                                Import
                            </a>

                            <form asp-controller="Account"
                                  asp-action="Logout"
                                  method="post"
                                  class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-link nav-link text-dark p-0 text-decoration-none">
                                    Logout
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="ms-auto d-flex flex-column flex-lg-row align-items-lg-center gap-2 gap-lg-3 mt-3 mt-lg-0">
                            <a asp-controller="Account"
                                   asp-action="Login"
                                   class="nav-link text-dark p-0">
                                Login
                            </a>

                            <a asp-controller="Account"
                                   asp-action="Register"
                                   class="btn btn-outline-primary btn-sm">
                                Register
                            </a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-3 px-md-4 px-lg-5 flex-grow-1">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mt-3 shadow-sm" role="alert">
                @TempData["SuccessMessage"]
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert"
                        aria-label="Close"></button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mt-3 shadow-sm" role="alert">
                @TempData["ErrorMessage"]
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert"
                        aria-label="Close"></button>
            </div>
        }

        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top text-muted bg-white mt-auto">
        <div class="container-fluid px-3 px-md-4 px-lg-5 py-3">
            &copy; 2026 - EProject.Web
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>