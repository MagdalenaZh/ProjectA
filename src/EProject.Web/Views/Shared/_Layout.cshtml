<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EProject.Web</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EProject.Web.styles.css" asp-append-version="true" />
</head>

<body class="d-flex flex-column min-vh-100 bg-body-tertiary">
    <header>
        <nav class="navbar navbar-expand-lg bg-white border-bottom shadow-sm mb-4">
            <div class="container-fluid px-3 px-md-4 px-lg-5">
                <a class="navbar-brand fw-bold fs-4"
                       asp-controller="Home"
                       asp-action="Index">
                    e-Project
                </a>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <span class="nav-link text-dark">
                        Hello, @User.Identity.Name
                    </span>
                }

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <ul class="navbar-nav ms-auto nav-auth-list mt-3 mt-lg-0">
                            <li class="nav-item">
                                <a asp-controller="Projects"
                                       asp-action="Create"
                                       asp-route-returnUrl="@Context.Request.Path"
                                       class="btn btn-primary">
                                    Add Project
                                </a>
                            </li>

                            <li class="nav-item">
                                <a asp-controller="Projects"
                                       asp-action="Index"
                                       class="nav-link nav-action-link text-dark">
                                    My Projects
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link nav-action-link text-dark fw-bold"
                                   asp-controller="Search"
                                   asp-action="Index">
                                    Search
                                </a>
                            </li>

                            <li class="nav-item">
                                <form asp-controller="Account"
                                      asp-action="Logout"
                                      method="post"
                                      class="d-inline w-100">
                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="nav-link nav-action-link nav-action-button text-dark border-0 bg-transparent">
                                        Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav ms-auto nav-auth-list mt-3 mt-lg-0">
                            <li class="nav-item">
                                <a class="nav-link nav-action-link text-dark"
                                       asp-controller="Account"
                                       asp-action="Login">
                                    Login
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link nav-action-link nav-action-primary"
                                       asp-controller="Account"
                                       asp-action="Register">
                                    Register
                                </a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-3 px-md-4 px-lg-5 flex-grow-1">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mt-3 shadow-sm" role="alert">
                @TempData["SuccessMessage"]
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert"
                        aria-label="Close">
                </button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mt-3 shadow-sm" role="alert">
                @TempData["ErrorMessage"]
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert"
                        aria-label="Close">
                </button>
            </div>
        }

        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top text-muted bg-white mt-auto">
        <div class="container-fluid px-3 px-md-4 px-lg-5 py-3">
            &copy; 2026 - EProject.Web
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>